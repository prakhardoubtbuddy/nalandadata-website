# Backend API URL — set this to your actual server in .env (never commit .env)
REACT_APP_BACKEND_URL=http://localhost:8001

# Dev server websocket port (set to 443 when running behind HTTPS proxy)
WDS_SOCKET_PORT=3000

# Enable background health-check polling
ENABLE_HEALTH_CHECK=false

# PostHog analytics — get these from your PostHog project settings
REACT_APP_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
